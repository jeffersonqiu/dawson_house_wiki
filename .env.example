# Copy to .env and fill in. Never commit .env.
#
# Google Cloud: create OAuth 2.0 Client ID (Desktop app)
# Enable: Google Drive API + Google Sheets API
# https://console.cloud.google.com/apis/credentials

USER_GOOGLE_EMAIL=you@gmail.com
GOOGLE_OAUTH_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=....

# Optional: device flow works better in Cursor agent (default auto)
# WORKSPACE_MCP_AUTH_FLOW=auto
