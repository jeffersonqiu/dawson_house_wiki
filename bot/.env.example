# Copy to bot/.env and fill in. Never commit bot/.env.

# 1. Message @BotFather on Telegram -> /newbot -> follow prompts -> copy the token here.
#    This is the Conversation agent (chat + /research) — telegram_bot.py.
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenFromBotFather

# 1b. Create a SECOND bot via @BotFather (a separate /newbot) for quick-capture
#     (/note, photos, daily review) — capture_bot.py. Keeping it separate means
#     photos sent to the Conversation bot for discussion are never mistaken for
#     data to file away; only photos sent to THIS bot are captured.
CAPTURE_BOT_TOKEN=123456789:AAAnotherExampleTokenFromBotFather

# 1c. Optional — the capture bot's @username (no "@"), so the Conversation bot
#     can point users at it when they send it a photo.
# CAPTURE_BOT_USERNAME=YourCaptureBot

# 2. Message @userinfobot on Telegram to get your numeric user ID. Comma-separate
#    multiple IDs (e.g. yourself + Marcella) if more than one person should have access.
#    Same list applies to both bots.
TELEGRAM_ALLOWED_USER_IDS=111111111,222222222

# 3. Your OpenAI API key (https://platform.openai.com/api-keys).
#    Default model/provider for both everyday chat and /research (see LLM_MODEL
#    below) — required unless you override BOTH LLM_MODEL and RESEARCH_LLM_MODEL
#    to use other providers. If missing, the bot still starts, but chat/research
#    reply that they aren't configured yet (soft-required).
OPENAI_API_KEY=sk-...

# 4. Your Tavily API key (https://tavily.com — free tier available). Always
#    required: /research's web_search tool is backed by Tavily, regardless of
#    which LLM(s) you configure below. Also soft-required, same as above.
TAVILY_API_KEY=tvly-...

# --- Model-agnostic agents (optional) ---
# Both everyday chat and /research run on any litellm-supported provider via a
# "<provider>/<model>" string. Defaults to "openai/gpt-4o-mini" for both.
# To use Claude instead, e.g.:
#   LLM_MODEL=anthropic/claude-sonnet-4-6
#   ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=openai/gpt-4o-mini

# Optional, legacy — if set (and LLM_MODEL above is unset), LLM_MODEL defaults
# to anthropic/<CLAUDE_MODEL> instead of openai/gpt-4o-mini.
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional — overrides the model used by /research only (default: same as
# LLM_MODEL). Useful if you want cheap/fast chat but a stronger model for
# research, or vice versa.
# RESEARCH_LLM_MODEL=anthropic/claude-sonnet-4-6

# --- Quick-capture / daily review (optional) ---
# IANA timezone for /note timestamps and the daily review schedule below.
# WIKI_TZ=Asia/Singapore

# Hour (0-23, in WIKI_TZ) at which the end-of-day clarification review runs.
# DAILY_REVIEW_HOUR=21

# Max clarifying questions asked per day during the review.
# DAILY_REVIEW_MAX_QUESTIONS=3

# --- GCP deployment only (leave unset for local runs) ---
# If set, and a required *_API_KEY / TELEGRAM_BOT_TOKEN / CAPTURE_BOT_TOKEN
# above is left blank, the bot fetches it from GCP Secret Manager (secret ID ==
# variable name) in this project, using the VM's Application Default
# Credentials. See bot/gcp/setup-secrets.sh.
# GCP_PROJECT_ID=citric-inkwell-308409
