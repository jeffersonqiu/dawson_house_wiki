# Copy to bot/.env and fill in. Never commit bot/.env.

# 1. Message @BotFather on Telegram -> /newbot -> follow prompts -> copy the token here.
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenFromBotFather

# 2. Message @userinfobot on Telegram to get your numeric user ID. Comma-separate
#    multiple IDs (e.g. yourself + Marcella) if more than one person should have access.
TELEGRAM_ALLOWED_USER_IDS=111111111,222222222

# 3. Your Anthropic API key (https://console.anthropic.com/settings/keys).
ANTHROPIC_API_KEY=sk-ant-...

# Optional — defaults to claude-sonnet-4-6 if unset.
CLAUDE_MODEL=claude-sonnet-4-6
