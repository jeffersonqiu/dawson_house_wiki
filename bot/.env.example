# Copy to bot/.env and fill in. Never commit bot/.env.

# 1. Message @BotFather on Telegram -> /newbot -> follow prompts -> copy the token here.
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenFromBotFather

# 2. Message @userinfobot on Telegram to get your numeric user ID. Comma-separate
#    multiple IDs (e.g. yourself + Marcella) if more than one person should have access.
TELEGRAM_ALLOWED_USER_IDS=111111111,222222222

# 3. Your Anthropic API key (https://console.anthropic.com/settings/keys).
#    Always required: /research's web_search tool always uses Claude directly,
#    no matter what LLM_MODEL below is set to.
ANTHROPIC_API_KEY=sk-ant-...

# Optional — model used by /research (must be a Claude model). Also used as
# the default for LLM_MODEL below if that's unset. Defaults to
# claude-sonnet-4-6 if unset.
CLAUDE_MODEL=claude-sonnet-4-6

# --- Model-agnostic Conversation agent (optional) ---
# Everyday chat (not /research) can run on any litellm-supported provider via
# a "<provider>/<model>" string. Defaults to "anthropic/<CLAUDE_MODEL>".
# To use ChatGPT instead, e.g.:
#   LLM_MODEL=openai/gpt-4o-mini
#   OPENAI_API_KEY=sk-...
# (ANTHROPIC_API_KEY above is still required for /research.)
# LLM_MODEL=anthropic/claude-sonnet-4-6

# --- GCP deployment only (leave unset for local runs) ---
# If set, and a required *_API_KEY / TELEGRAM_BOT_TOKEN above is left blank,
# the bot fetches it from GCP Secret Manager (secret ID == variable name) in
# this project, using the VM's Application Default Credentials.
# See bot/gcp/setup-secrets.sh.
# GCP_PROJECT_ID=citric-inkwell-308409
